# Copy this to `.env` (same folder) and update values as needed.

DB_NAME=student_management
DB_USER=student_app
DB_PASSWORD=student_pass
DB_HOST=127.0.0.1
DB_PORT=3306

# Used by Flask session
SECRET_KEY=student-management-secret-key

# Used by MySQL container (only in docker-compose.yml)
MYSQL_ROOT_PASSWORD=rootpass
